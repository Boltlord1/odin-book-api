// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

generator json {
  provider = "prisma-json-types-generator"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String     @id
  name          String     @unique
  display       String
  avatar        String     @default("odin-book/avatar/default")
  posts         Post[]     @relation("author")
  comments      Comment[]
  identities    Identity[]
  likedPosts    Post[]     @relation("liked_posts")
  likedComments Comment[]  @relation("liked_comments")
  follows       User[]     @relation("follows")
  followers     User[]     @relation("follows")
}

model Identity {
  provider Provider
  id       String
  user     User     @relation(fields: [userId], references: [id])
  userId   String
  data     Json?

  @@id(name: "providerId", [provider, id])
  @@unique(name: "connection", [userId, provider])
}

enum Provider {
  Email
  Github
  Google
}

model Post {
  id        String    @id
  title     String
  content   String?
  createdAt DateTime  @default(now())
  author    User      @relation("author", fields: [authorId], references: [id])
  authorId  String
  comments  Comment[]
  likedBy   User[]    @relation("liked_posts")
  images    Image[]
}

model Image {
  id       String @id
  publicId String @unique
  height   Int
  width    Int
  post     Post   @relation(fields: [postId], references: [id])
  postId   String
}

model Comment {
  id        String   @id
  content   String
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  post      Post     @relation(fields: [postId], references: [id])
  postId    String
  likedBy   User[]   @relation("liked_comments")
}
