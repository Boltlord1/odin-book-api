// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String     @id @default(uuid()) @db.Uuid
  name     String     @unique @db.VarChar(255)
  display  String     @db.VarChar(255)
  avatar   String     @db.VarChar(255)
  posts    Post[] @relation("author")
  comments Comment[]
  local    LocalUser?
  oauth    OauthUser?
  likedPosts Post[] @relation("liked_posts")
  likedComments Comment[] @relation("liked_comments")
  follows User[] @relation("follows")
  followers User[] @relation("follows")
}

model LocalUser {
  hash   String @db.VarChar(255)
  user   User   @relation(fields: [userId], references: [id])
  userId String @id @db.Uuid
}

model OauthUser {
  provider Provider
  id       String   @db.VarChar(255)
  user     User     @relation(fields: [userId], references: [id])
  userId   String   @unique @db.Uuid

  @@id(name: "providerId", [provider, id])
}

enum Provider {
  github
  google
}

model Post {
  id        String    @id @default(uuid()) @db.Uuid
  title     String    @db.VarChar(255)
  content   String    @db.Text
  createdAt DateTime  @default(now())
  author    User      @relation("author", fields: [authorId], references: [id])
  authorId  String    @db.Uuid
  comments  Comment[]
  likedBy User[] @relation("liked_posts")
}

model Comment {
  id        String   @id @default(uuid()) @db.Uuid
  content   String   @db.Text
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String   @db.Uuid
  post      Post     @relation(fields: [postId], references: [id])
  postId    String   @db.Uuid
  likedBy User[] @relation("liked_comments")
}
