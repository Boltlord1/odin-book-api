// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["fullTextSearchPostgres"]
}

generator json {
  provider = "prisma-json-types-generator"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String     @id
  name           String     @unique
  display        String
  avatar         String?
  deletedAt      DateTime?
  followingCount Int        @default(0)
  followerCount  Int        @default(0)
  postCount      Int        @default(0)
  commentCount   Int        @default(0)
  identities     Identity[]
  posts          Post[]     @relation("author")
  comments       Comment[]
  messages       Message[]
  chats          Chat[]
  visibleChats   Chat[]     @relation("visible_chats")
  likedPosts     Post[]     @relation("liked_posts")
  likedComments  Comment[]  @relation("liked_comments")
  following      User[]     @relation("follow")
  followers      User[]     @relation("follow")
  password       Password?
}

model Identity {
  provider Provider
  id       String
  user     User     @relation(fields: [userId], references: [id])
  userId   String

  /// [IdentityDataType]
  data Json

  @@id(name: "providerId", [provider, id])
  @@unique(name: "connection", [userId, provider])
}

model Password {
  id     String @id
  hash   String
  user   User   @relation(fields: [userId], references: [id])
  userId String @unique
}

enum Provider {
  Email
  Github
  Google
}

model Post {
  id           String    @id
  title        String?
  content      String?
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?
  likeCount    Int       @default(0)
  commentCount Int       @default(0)
  author       User?     @relation("author", fields: [authorId], references: [id])
  authorId     String?
  comments     Comment[]
  likedBy      User[]    @relation("liked_posts")
  images       Image[]
}

model Image {
  id       String @id
  publicId String @unique
  height   Int
  width    Int
  post     Post   @relation(fields: [postId], references: [id])
  postId   String
}

model Comment {
  id         String    @id
  content    String?
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?
  likeCount  Int       @default(0)
  childCount Int       @default(0)
  author     User?     @relation(fields: [authorId], references: [id])
  authorId   String?
  post       Post      @relation(fields: [postId], references: [id])
  postId     String
  parent     Comment?  @relation("thread", fields: [parentId], references: [id])
  parentId   String?
  children   Comment[] @relation("thread")
  likedBy    User[]    @relation("liked_comments")
}

model Message {
  id        String    @id
  content   String?
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  author    User      @relation(fields: [authorId], references: [id])
  authorId  String
  chat      Chat      @relation(fields: [chatId], references: [id])
  chatId    String
}

model Chat {
  id           String    @id
  name         String?
  messageCount Int       @default(0)
  users        User[]
  visibileTo   User[]    @relation("visible_chats")
  messages     Message[]
  type         ChatType
}

enum ChatType {
  Private
  Group
}
